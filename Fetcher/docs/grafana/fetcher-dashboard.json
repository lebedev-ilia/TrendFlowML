{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Ingestion Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(rate(fetcher_videos_downloaded_total[5m])) * 60", "refId": "A", "legendFormat": "per min" }],
      "title": "Throughput (videos/min)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(fetcher_videos_downloaded_total)", "refId": "A", "legendFormat": "Total" }],
      "title": "Total Videos Downloaded",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(rate(fetcher_videos_failed_total[5m])) * 60", "refId": "A", "legendFormat": "failed/min" }],
      "title": "Failed (per min)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "max": 1, "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "green", "value": 0.6 }] }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "expr": "sum(rate(fetcher_cache_hits_total[5m])) / (sum(rate(fetcher_cache_hits_total[5m])) + sum(rate(fetcher_cache_miss_total[5m])))", "refId": "A", "legendFormat": "Hit ratio" }],
      "title": "Cache Hit Ratio",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "Queue & Worker Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "displayMode": "gradient", "minVizHeight": 16, "minVizWidth": 8, "namePlacement": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true },
      "targets": [{ "expr": "fetcher_celery_queue_pending", "refId": "A", "legendFormat": "{{ queue }}" }],
      "title": "Celery Queue Depth (pending)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "auto", "spanNulls": false }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "targets": [{ "expr": "sum(fetcher_celery_queue_pending) by (queue)", "refId": "A", "legendFormat": "{{ queue }}" }],
      "title": "Queue Depth Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 102,
      "panels": [],
      "title": "Cache & Download Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "auto", "spanNulls": false }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "targets": [
        { "expr": "sum(rate(fetcher_cache_hits_total[5m])) by (platform)", "refId": "A", "legendFormat": "hits {{ platform }}" },
        { "expr": "sum(rate(fetcher_cache_miss_total[5m])) by (platform)", "refId": "B", "legendFormat": "miss {{ platform }}" }
      ],
      "title": "Cache Hits / Misses",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "auto", "spanNulls": false }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 13 },
      "id": 8,
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(fetcher_download_latency_seconds_bucket[5m])) by (le, platform))", "refId": "A", "legendFormat": "P50 {{ platform }}" },
        { "expr": "histogram_quantile(0.95, sum(rate(fetcher_download_latency_seconds_bucket[5m])) by (le, platform))", "refId": "B", "legendFormat": "P95 {{ platform }}" }
      ],
      "title": "Download Latency (P50 / P95)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 103,
      "panels": [],
      "title": "Platform Health & Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "auto", "spanNulls": false }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 19 },
      "id": 9,
      "targets": [
        { "expr": "sum(rate(fetcher_youtube_429_total[5m])) by (operation)", "refId": "A", "legendFormat": "429 {{ operation }}" },
        { "expr": "sum(rate(fetcher_youtube_403_total[5m])) by (operation)", "refId": "B", "legendFormat": "403 {{ operation }}" }
      ],
      "title": "YouTube 429 / 403",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "auto", "spanNulls": false }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 19 },
      "id": 10,
      "targets": [
        { "expr": "sum(rate(fetcher_videos_failed_total[5m])) by (platform, reason)", "refId": "A", "legendFormat": "{{ platform }} {{ reason }}" },
        { "expr": "sum(rate(circuit_breaker_tripped_total[5m])) by (operation)", "refId": "B", "legendFormat": "CB {{ operation }}" }
      ],
      "title": "Failures & Circuit Breaker",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "id": 11,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "fetcher_processor_queue_size", "refId": "A", "legendFormat": "DataProcessor queue" }],
      "title": "DataProcessor Queue Size (backpressure)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fetcher", "ingestion"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Fetcher Observability",
  "uid": "fetcher-observability",
  "version": 1,
  "weekStart": ""
}
