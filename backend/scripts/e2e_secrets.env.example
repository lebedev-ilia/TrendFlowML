# Локальные секреты для E2E (не коммитить).
# Скопируйте в backend/.e2e/secrets.env — каталог backend/.e2e/ в .gitignore.
#
#   cp backend/scripts/e2e_secrets.env.example backend/.e2e/secrets.env
#   chmod 600 backend/.e2e/secrets.env
#
# Принять условия gated-моделей на HuggingFace перед использованием токена:
#   https://hf.co/pyannote/speaker-diarization-community-1

HF_TOKEN=hf_replace_me
# HUGGINGFACE_TOKEN=hf_replace_me
