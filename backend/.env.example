# Скопируйте в .env и задайте значения. Префикс переменных: TF_BACKEND_
# Подробности: docs/CONFIGURATION.md, docs/PORTFOLIO_READINESS_CHECKLIST.md

# development | production | staging — в production/staging слабый JWT блокирует старт (см. SECURITY.md)
# TF_BACKEND_DEPLOYMENT_ENV=development

# Обязательно смените в production
TF_BACKEND_JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL (async/sync DSN для SQLAlchemy)
TF_BACKEND_DB_DSN=postgresql+psycopg://trendflow:trendflow@localhost:5432/trendflow

TF_BACKEND_REDIS_URL=redis://localhost:6379/0

# false в production — использовать только Alembic-миграции
TF_BACKEND_DB_AUTO_CREATE=false

TF_BACKEND_DEBUG=false

# CORS: "*" (dev) или список origin через запятую
# TF_BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Опционально: админы по email (через запятую)
# TF_BACKEND_ADMIN_EMAILS=admin@example.com

# Пути (пусто = относительно корня репозитория / layout по умолчанию)
# TF_BACKEND_STORAGE_ROOT=
# TF_BACKEND_RESULT_STORE_BASE=
# TF_BACKEND_FRAMES_DIR_BASE=
# TF_BACKEND_RAW_UPLOADS_DIR=
# TF_BACKEND_DATAPROC_ROOT=
# TF_BACKEND_VISUAL_CFG_DEFAULT=

# DataProcessor API (Этап HTTP-оркестрации)
TF_BACKEND_DATAPROCESSOR_API_URL=http://localhost:8001
# TF_BACKEND_DATAPROCESSOR_API_KEY=
# TF_BACKEND_DATAPROCESSOR_POLL_INTERVAL=5
# TF_BACKEND_DATAPROCESSOR_TIMEOUT_SECONDS=3600
# TF_BACKEND_DATAPROCESSOR_GLOBAL_CONFIG_PATH=

# Fetcher (YouTube / URL ingestion)
TF_BACKEND_FETCHER_API_URL=http://localhost:8000
# TF_BACKEND_FETCHER_API_KEY=
# TF_BACKEND_FETCHER_TIMEOUT_SECONDS=30

# Защита POST /api/runs/{id}/trigger-processing (вызов от Fetcher)
# TF_BACKEND_RUN_TRIGGER_API_KEY=

# Синхронизация статуса ingestion (Celery beat)
# TF_BACKEND_INGESTION_SYNC_INTERVAL_SECONDS=20
# TF_BACKEND_INGESTION_SYNC_LOOKBACK_HOURS=6
