# automation/fetcher/.env.example — скопируй в .env и заполни. НЕ коммитить .env.

# --- RunPod (тот же аккаунт, что у ML-раннера automation/runner/) ---
RUNPOD_API_KEY=rpa_ЗАМЕНИ

# --- VK (Третий бот — наблюдатель Fetcher) ---
VK_TOKEN3=vk1.a.ЗАМЕНИ_ТОКЕН_ТРЕТЬЕГО_БОТА
VK_OWNER_ID=344881779
VK_API_VERSION=5.199
FETCHER_WATCHDOG_MODEL=claude-haiku-4-5-20251001

# --- Секреты кампании (обязательно перед launch) ---
HF_TOKEN=hf_ЗАМЕНИ

# --- Поды (спецификация подтверждена 2026-07-16: cpu3g@2vCPU=8ГБ RAM, $0.08/ч) ---
FETCHER_POD_VCPU=2
FETCHER_POD_CONTAINER_DISK_GB=20
FETCHER_POD_MAX_HOURLY_USD=0.12
FETCHER_VOLUME_GB=15
FETCHER_PREFERRED_DATACENTERS=EU-CZ-1,EU-RO-1,EU-SE-1,US-KS-2,US-IL-1

# --- Мониторинг ---
FETCHER_WATCHDOG_INTERVAL_SEC=3600
FETCHER_REPORT_INTERVAL_SEC=3600
