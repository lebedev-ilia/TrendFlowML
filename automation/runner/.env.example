# Скопируй в .env и заполни. .env НЕ коммить (см. .gitignore).

# --- VK (канал вопрос-ответ) ---
VK_TOKEN=vk1.a.ЗАМЕНИ_НА_СВОЙ_ТОКЕН
VK_OWNER_ID=344881779
VK_API_VERSION=5.199
# Второй бот-ассистент (разговорный помощник):
VK_TOKEN2=vk1.a.ЗАМЕНИ_ТОКЕН_ВТОРОГО_БОТА
ASSISTANT_MODEL=claude-opus-4-8

# --- RunPod ---
RUNPOD_API_KEY=rpa_ЗАМЕНИ
# Необязательно: закрепить конкретный под для start (оставь пустым — поды идентичны, поднимаем любой).
RUNPOD_POD_ID=
# Необязательно: образ по умолчанию для создаваемых с нуля подов (если образец недоступен).
RUNPOD_DEFAULT_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

# --- Модель (аутентификация — через Claude Code / Max, отдельный ключ не нужен) ---
AGENT_MODEL=claude-opus-4-8
MAX_TURNS_PER_COMPONENT=200
# Второй агент (assistant.py): отвечает Первому + мониторит/чинит/перезапускает + чат с владельцем.
ASSISTANT_MODEL=claude-sonnet-4-6
# Быстрый авто-ответчик на вопросы Первого агента (supervisor.py) — латентность важнее глубины.
SUPERVISOR_MODEL=claude-haiku-4-5-20251001

# --- НЕТ дневного $-бюджета (сознательно). Единственные лимиты (см. AGENT_CONTEXT.md раздел 0): ---
#   1) % Claude 5ч/неделя — settings.json: limit_pct_stop=95 (сворачивание), limit_pct_hard=97
#      (жёсткий стоп; 97-100% — неприкосновенный резерв).
#   2) Баланс RunPod — settings.json: runpod_balance_warn_usd=1.0 (только предупреждение, не стоп).
#   3) Цена пода — settings.json: max_pod_hourly_usd=0.30 (обычно), max_pod_hourly_usd_short=0.60
#      (для коротких/быстрых прогонов).
# Порог простоя пода (сек) — НЕ лимит бюджета, просто не оставляем GPU крутиться без дела.
POD_IDLE_STOP_SEC=1200
