{
  "dashboard": {
    "title": "DataProcessor API - Overview",
    "tags": ["dataprocessor", "api"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Queue Length",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(dataprocessor_queue_length) by (priority)",
            "legendFormat": "{{priority}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "yaxes": [
          {"format": "short", "label": "Queue Length"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Active Runs",
        "type": "stat",
        "targets": [
          {
            "expr": "dataprocessor_active_runs",
            "legendFormat": "Active Runs"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 20, "color": "yellow"},
                {"value": 30, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Crashed Runs (Total)",
        "type": "stat",
        "targets": [
          {
            "expr": "dataprocessor_crashed_runs_total",
            "legendFormat": "Crashed Runs"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Processing Time (95th percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dataprocessor_processing_seconds_bucket[5m])) by (processor, component)",
            "legendFormat": "{{processor}}/{{component}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "yaxes": [
          {"format": "s", "label": "Processing Time"},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "Failure Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(dataprocessor_failures_total[5m]) by (processor, component, error_type)",
            "legendFormat": "{{processor}}/{{component}}/{{error_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "yaxes": [
          {"format": "short", "label": "Failures/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(dataprocessor_memory_bytes) by (run_id)",
            "legendFormat": "{{run_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "yaxes": [
          {"format": "bytes", "label": "Memory"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "Queue Wait Time (95th percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dataprocessor_queue_wait_seconds_bucket[5m]))",
            "legendFormat": "Queue Wait Time"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "yaxes": [
          {"format": "s", "label": "Wait Time"},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "title": "Component time from manifest (p95) by component",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(dataprocessor_component_stage_seconds_bucket[5m])) by (le, component))",
            "legendFormat": "{{component}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "yaxes": [
          {"format": "s", "label": "Stage wall time"},
          {"format": "short"}
        ]
      },
      {
        "id": 9,
        "title": "Component time from manifest (p95) by worker",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(dataprocessor_component_stage_seconds_bucket[5m])) by (le, worker_id, component))",
            "legendFormat": "{{worker_id}} / {{component}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "yaxes": [
          {"format": "s", "label": "Stage wall time"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Host: CPU + load1 (from scrapes /metrics)",
        "type": "graph",
        "targets": [
          {
            "expr": "dataprocessor_host_cpu_usage_ratio",
            "legendFormat": "cpu_ratio (0..1)"
          },
          {
            "expr": "dataprocessor_host_load1",
            "legendFormat": "load1"
          }
        ],
        "gridPos": {"h": 7, "w": 8, "x": 0, "y": 32},
        "yaxes": [
          {"format": "short", "label": "mixed"},
          {"format": "short"}
        ]
      },
      {
        "id": 11,
        "title": "Host: memory available",
        "type": "graph",
        "targets": [
          {
            "expr": "dataprocessor_host_memory_available_bytes",
            "legendFormat": "available"
          }
        ],
        "gridPos": {"h": 7, "w": 8, "x": 8, "y": 32},
        "yaxes": [
          {"format": "bytes", "label": "RAM available"},
          {"format": "short"}
        ]
      },
      {
        "id": 12,
        "title": "Host: disk free (set DATAPROCESSOR_HOST_DISK_PATH for extra mount)",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(dataprocessor_host_disk_free_bytes) by (mountpoint)",
            "legendFormat": "{{mountpoint}}"
          }
        ],
        "gridPos": {"h": 7, "w": 8, "x": 16, "y": 32},
        "yaxes": [
          {"format": "bytes", "label": "Free bytes"},
          {"format": "short"}
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  }
}

