{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "detalize_face_npz_v3",
  "producer": "detalize_face",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "total_frames",
      "processed_frames",
      "frames_dir",
      "analysis_fps",
      "analysis_width",
      "analysis_height",
      "ui_payload",
      "module_sampling_policy_version",
      "face_frames_sampling_policy_version",
      "write_primary_curves",
      "write_primary_compact_features"
    ]
  },
  "fields": {
    "frame_indices": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["N"] },
    "times_s": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },
    "face_present": { "required": true, "tier": "model_facing", "dtype": "bool", "shape": ["N"] },
    "processed_mask": { "required": true, "tier": "model_facing", "dtype": "bool", "shape": ["N"] },
    "primary_valid": { "required": true, "tier": "model_facing", "dtype": "bool", "shape": ["N"] },
    "face_count": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },
    "primary_tracking_id": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["N"] },
    "primary_compact_features": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N", 40] },
    "aggregated": { "required": true, "tier": "model_facing", "dtype": "object", "shape": [] },

    "primary_gaze_at_camera_prob": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "primary_blink_rate": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "primary_attention_score": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "primary_quality_proxy_score": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "primary_face_sharpness": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "primary_occlusion_proxy": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "primary_speech_activity_prob": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },

    "faces_agg": { "required": true, "tier": "analytics", "dtype": "object", "shape": [] },
    "summary": { "required": true, "tier": "analytics", "dtype": "object", "shape": [] },
    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}


