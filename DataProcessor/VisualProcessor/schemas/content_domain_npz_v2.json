{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "content_domain_npz_v2",
  "producer": "content_domain",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms",
      "db_name",
      "db_version",
      "db_digest"
    ],
    "optional_keys": [
      "db_path",
      "threshold_global",
      "threshold_per_label",
      "top_k",
      "confidence_threshold_top1",
      "clip_text_model_spec",
      "domain_db_dir",
      "core_clip_model_signature"
    ]
  },
  "fields": {
    "frame_indices": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["N"] },
    "times_s": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },

    "semantic_label_names": { "required": true, "tier": "model_facing", "dtype": "str", "shape": ["A"], "description": "label space: 'id:name' from domain db (ids are stable within db_digest)" },
    "threshold_per_label_arr": { "required": true, "tier": "debug", "dtype": "float32", "shape": ["A"], "description": "per-label thresholds aligned with semantic_label_names (NaN if not set)" },

    "track_ids": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": [1], "description": "video aggregate pseudo-track id (=0)" },
    "track_present_mask": { "required": true, "tier": "model_facing", "dtype": "bool", "shape": [1] },
    "track_topk_ids": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": [1, "K"] },
    "track_topk_scores": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": [1, "K"] },
    "track_is_confident_top1": { "required": true, "tier": "analytics", "dtype": "bool", "shape": [1] },

    "frame_topk_ids": { "required": true, "tier": "analytics", "dtype": "int32", "shape": ["N", "K"] },
    "frame_topk_scores": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N", "K"] },
    "frame_is_confident_top1": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["N"] },

    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] },
    "meta_json": { "required": true, "tier": "debug", "dtype": "str", "shape": [], "description": "meta as JSON string (cross-venv safe)" }
  }
}


