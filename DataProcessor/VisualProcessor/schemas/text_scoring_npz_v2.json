{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "text_scoring_npz_v2",
  "producer": "text_scoring",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "total_frames",
      "processed_frames",
      "frames_dir",
      "analysis_fps",
      "analysis_width",
      "analysis_height",
      "ui_payload",
      "ocr_npz",
      "use_face_data",
      "alignment_window_seconds",
      "motion_weight",
      "face_weight",
      "audio_weight",
      "min_ocr_confidence",
      "retain_raw_ocr_text",
      "store_debug_objects",
      "enable_text_peaks",
      "enable_language_entropy",
      "enable_text_movement_speed"
    ]
  },
  "fields": {
    "frame_indices": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["N"] },
    "times_s": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },
    "text_present": { "required": true, "tier": "model_facing", "dtype": "bool", "shape": [] },
    "text_presence": { "required": true, "tier": "model_facing", "dtype": "bool", "shape": ["N"] },
    "text_count_per_frame": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["N"] },

    "feature_names": { "required": true, "tier": "model_facing", "dtype": "object", "shape": ["F"] },
    "feature_values": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["F"] },

    "ocr_raw": { "required": false, "tier": "debug", "dtype": "object", "shape": ["M"] },
    "ocr_unique_elements": { "required": false, "tier": "debug", "dtype": "object", "shape": ["K"] },

    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}


