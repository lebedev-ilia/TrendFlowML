{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "ocr_extractor_npz_v2",
  "producer": "ocr_extractor",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "engine",
      "tesseract_lang",
      "tesseract_psm",
      "proposal_class",
      "retain_raw_ocr_text",
      "rec_model_spec",
      "ppocr_img_h",
      "ppocr_img_w"
    ]
  },
  "fields": {
    "frame_indices": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["N"] },
    "times_s": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },
    "ocr_raw": { "required": true, "tier": "analytics", "dtype": "object", "shape": ["R"], "description": "list[dict] rows (may be redacted)" },
    "meta_json": { "required": true, "tier": "debug", "dtype": "str", "shape": [], "description": "meta as JSON string" },
    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}


