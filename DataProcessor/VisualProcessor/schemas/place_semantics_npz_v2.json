{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "place_semantics_npz_v2",
  "producer": "place_semantics",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms",
      "embedding_service_url",
      "place_category",
      "topk",
      "similarity_threshold",
      "threshold_global",
      "min_track_length",
      "max_gap_sec",
      "num_tracks",
      "num_places",
      "num_frames",
      "db_name",
      "db_version",
      "db_digest"
    ],
    "optional_keys": [
      "embedding_model",
      "places_found_count"
    ]
  },
  "fields": {
    "frame_indices": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["N"], "description": "Frame indices (strictly = core_object_detections.frame_indices)" },
    "times_s": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"], "description": "Time stamps from union_timestamps_sec[frame_indices]" },
    
    "semantic_label_names": { "required": true, "tier": "model_facing", "dtype": "str", "shape": ["A"], "description": "canonical label space: 'int:name' (id is stable within db_digest)" },
    "semantic_object_ids": { "required": true, "tier": "debug", "dtype": "str", "shape": ["A"], "description": "original object UUIDs from Embedding Service, aligned with semantic_label_names" },
    "threshold_per_label_arr": { "required": true, "tier": "debug", "dtype": "float32", "shape": ["A"], "description": "per-label thresholds (NaN if not set)" },
    
    "track_ids": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["T"], "description": "Track IDs (temporal segments, one per detected place)" },
    "track_present_mask": { "required": true, "tier": "model_facing", "dtype": "bool", "shape": ["T"], "description": "Track present mask (always True for valid tracks)" },
    "track_topk_ids": { "required": true, "tier": "model_facing", "dtype": "int32", "shape": ["T", "K"], "description": "Per-track top-K place IDs (aggregated over track frames)" },
    "track_topk_scores": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["T", "K"], "description": "Per-track top-K similarity scores (max over track frames)" },
    "track_is_confident_top1": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["T"], "description": "Per-track confidence flag (top-1 score >= similarity_threshold)" },
    "track_topk_evidence_frame_indices": { "required": true, "tier": "debug", "dtype": "int32", "shape": ["T", "K"], "description": "Union frame indices where similarity is maximum for each top-K place in each track" },
    
    "frame_topk_ids": { "required": true, "tier": "analytics", "dtype": "int32", "shape": ["N", "K"], "description": "Per-frame top-K place IDs" },
    "frame_topk_scores": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N", "K"], "description": "Per-frame top-K similarity scores (0.0-1.0, NaN where no result)" },
    "frame_is_confident_top1": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["N"], "description": "Per-frame confidence flag (top-1 score >= similarity_threshold)" },
    
    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [], "description": "metadata dictionary" },
    "meta_json": { "required": true, "tier": "debug", "dtype": "str", "shape": [], "description": "meta as JSON string (cross-venv safe)" }
  }
}

