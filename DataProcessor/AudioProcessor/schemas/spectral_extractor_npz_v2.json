{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "spectral_extractor_npz_v2",
  "producer": "spectral_extractor",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "device_used",
      "scheduler_knobs",
      "resource_metrics",
      "error",
      "spectral_contract_version",
      "features_enabled",
      "sample_rate",
      "hop_length",
      "n_fft",
      "average_channels",
      "keep_contrast_bands",
      "duration",
      "segments_count",
      "spectral_features_correlation"
    ]
  },
  "fields": {
    "feature_names": { "required": true, "tier": "model_facing", "dtype": "object", "shape": ["F"] },
    "feature_values": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["F"] },

    "segment_start_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_end_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_center_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_mask": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["N"] },

    "centroid_mean_by_segment": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "bandwidth_mean_by_segment": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "flatness_mean_by_segment": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "rolloff_mean_by_segment": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "zcr_mean_by_segment": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },

    "contrast_mean_by_segment": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "slope_mean_by_segment": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },

    "spectral_contrast_bands": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["B", "T"] },

    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}
