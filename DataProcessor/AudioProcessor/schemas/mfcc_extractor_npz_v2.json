{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "mfcc_extractor_npz_v2",
  "producer": "mfcc_extractor",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "device_used",
      "scheduler_knobs",
      "resource_metrics",
      "error",
      "mfcc_contract_version",
      "features_enabled",
      "mfcc_npy"
    ]
  },
  "fields": {
    "feature_names": { "required": true, "tier": "model_facing", "dtype": "object", "shape": ["F"] },
    "feature_values": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["F"] },

    "segment_start_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_end_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_center_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_mask": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["N"] },

    "mfcc_mean": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },
    "mfcc_std": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },
    "mfcc_min": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },
    "mfcc_max": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },

    "delta_mean": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },
    "delta_std": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },
    "delta_delta_mean": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },
    "delta_delta_std": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["M"] },

    "mfcc_mean_by_segment": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["N", "M"] },
    "mfcc_energy_by_segment": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },
    "delta_mean_by_segment": { "required": false, "tier": "model_facing", "dtype": "float32", "shape": ["N", "M"] },

    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}
