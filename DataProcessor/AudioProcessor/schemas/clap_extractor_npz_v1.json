{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "clap_extractor_npz_v1",
  "producer": "clap_extractor",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "device_used",
      "scheduler_knobs",
      "resource_metrics",
      "error",
      "clap_contract_version",
      "features_enabled",
      "sample_rate",
      "embedding_dim",
      "max_audio_length_sec",
      "trimmed_segments_count",
      "trimmed_ratio"
    ]
  },
  "fields": {
    "feature_names": { "required": true, "tier": "model_facing", "dtype": "object", "shape": ["F"] },
    "feature_values": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["F"] },

    "embedding": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["D"] },
    "embedding_present": { "required": true, "tier": "analytics", "dtype": "bool", "shape": [] },

    "embedding_sequence": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N", "D"] },
    "segment_start_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_end_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_center_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_mask": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["N"] },

    "segment_embedding_norm": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["N"] },

    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}

