{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "hpss_extractor_npz_v1",
  "producer": "hpss_extractor",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "error",
      "hpss_contract_version",
      "features_enabled",
      "sample_rate",
      "n_fft",
      "hop_length",
      "hpss_kernel_size",
      "hpss_margin",
      "hpss_power",
      "hpss_harmonic_npy_path",
      "hpss_percussive_npy_path",
      "hpss_dominance"
    ]
  },
  "fields": {
    "feature_names": { "required": true, "tier": "model_facing", "dtype": "object", "shape": ["F"] },
    "feature_values": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["F"] },

    "segment_start_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_end_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_center_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_mask": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["N"] },

    "hpss_harmonic_share_by_segment": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },
    "hpss_percussive_share_by_segment": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["N"] },

    "hpss_harmonic_share_series": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["T"] },
    "hpss_percussive_share_series": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["T"] },

    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}
