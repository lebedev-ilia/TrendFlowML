{
  "schema_system_version": "vp_schema_v1",
  "schema_version": "tempo_extractor_npz_v1",
  "producer": "tempo_extractor",
  "artifact_kind": "npz",
  "allow_extra_keys": false,
  "meta": {
    "required_keys": [
      "producer",
      "producer_version",
      "schema_version",
      "created_at",
      "platform_id",
      "video_id",
      "run_id",
      "config_hash",
      "sampling_policy_version",
      "dataprocessor_version",
      "status",
      "empty_reason",
      "models_used",
      "model_signature",
      "stage_timings_ms"
    ],
    "optional_keys": [
      "device_used",
      "scheduler_knobs",
      "resource_metrics",
      "error",
      "duration",
      "segments_count",
      "sample_rate",
      "tempo_contract_version"
    ]
  },
  "fields": {
    "feature_names": { "required": true, "tier": "model_facing", "dtype": "object", "shape": ["F"] },
    "feature_values": { "required": true, "tier": "model_facing", "dtype": "float32", "shape": ["F"] },

    "segment_start_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_end_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_center_sec": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },
    "segment_mask": { "required": true, "tier": "analytics", "dtype": "bool", "shape": ["N"] },

    "bpm_by_segment": { "required": true, "tier": "analytics", "dtype": "float32", "shape": ["N"] },

    "tempo_estimates": { "required": false, "tier": "analytics", "dtype": "float32", "shape": ["E"] },
    "warnings": { "required": false, "tier": "debug", "dtype": "object", "shape": ["W"] },

    "meta": { "required": true, "tier": "debug", "dtype": "object", "shape": [] }
  }
}
