# Copy to `.env` (gitignored). Canonical list: api/docs/ENVIRONMENT_VARIABLES.md
# Alignment guide (local vs docker vs E2E): docs/ENV_ALIGNMENT.md

# --- Local dev (host, без docker) — раскомментируйте и подставьте REPO_ROOT ---
# REPO_ROOT=/abs/path/to/TrendFlowML
# DP_MODELS_ROOT=${REPO_ROOT}/DataProcessor/dp_models/bundled_models
# TREND_STORAGE_BACKEND=fs
# TREND_FS_ROOT=${REPO_ROOT}/storage
# STORAGE_TYPE=fs
# STORAGE_ROOT=${REPO_ROOT}/storage

# --- Storage adapter (DataProcessor/storage) — docker default ---
TREND_STORAGE_BACKEND=s3
TREND_FS_ROOT=_runs

# --- API storage (DataProcessor/api) — must match TREND_FS_ROOT for same run ---
# STORAGE_TYPE=fs
# STORAGE_ROOT=/data/storage

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- MinIO / S3-compatible storage ---
MINIO_ROOT_USER=trendflow
MINIO_ROOT_PASSWORD=trendflow123
S3_ENDPOINT=http://minio:9000
S3_BUCKET=trendflow
S3_PREFIX=trendflowml
AWS_ACCESS_KEY_ID=trendflow
AWS_SECRET_ACCESS_KEY=trendflow123
AWS_DEFAULT_REGION=us-east-1

# --- Triton (docker compose --profile triton) ---
TRITON_HTTP_URL=http://triton:8000

# --- Models (no-network, ModelManager) ---
DP_MODELS_ROOT=/app/models
