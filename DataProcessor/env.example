# Copy to `.env` (gitignored). Canonical list: api/docs/ENVIRONMENT_VARIABLES.md
# Storage adapter (FS): storage/settings.py uses TREND_STORAGE_BACKEND, TREND_FS_ROOT

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- MinIO / S3-compatible storage ---
MINIO_ROOT_USER=trendflow
MINIO_ROOT_PASSWORD=trendflow123
S3_ENDPOINT=http://minio:9000
S3_BUCKET=trendflow
S3_PREFIX=trendflowml
AWS_ACCESS_KEY_ID=trendflow
AWS_SECRET_ACCESS_KEY=trendflow123
AWS_DEFAULT_REGION=us-east-1

# --- Storage adapter (DataProcessor/storage) ---
TREND_STORAGE_BACKEND=s3
TREND_FS_ROOT=_runs

# --- API storage (DataProcessor/api) — see ENVIRONMENT_VARIABLES.md ---
# STORAGE_TYPE=fs
# STORAGE_ROOT=/data/storage

# --- Triton (docker compose --profile triton) ---
TRITON_HTTP_URL=http://triton:8000

# --- Models (no-network, ModelManager) ---
DP_MODELS_ROOT=/app/models
